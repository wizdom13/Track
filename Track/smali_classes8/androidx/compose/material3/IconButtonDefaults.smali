\u0010\n\u001a\u00020\u000b8GX\u0087\u0004\u00f8\u0001\u0000\u00f8\u0001\u0001\u00a2\u0006\u0010\n\u0002\u0010\u000f\u0012\u0004\u0008\u000c\u0010\u0002\u001a\u0004\u0008\r\u0010\u000eR\u001a\u0010\u0010\u001a\u00020\u00048GX\u0087\u0004\u00a2\u0006\u000c\u0012\u0004\u0008\u0011\u0010\u0002\u001a\u0004\u0008\u0012\u0010\u0007R\u001a\u0010\u0013\u001a\u00020\u00048GX\u0087\u0004\u00a2\u0006\u000c\u0012\u0004\u0008\u0014\u0010\u0002\u001a\u0004\u0008\u0015\u0010\u0007R\u001a\u0010\u0016\u001a\u00020\u00048GX\u0087\u0004\u00a2\u0006\u000c\u0012\u0004\u0008\u0017\u0010\u0002\u001a\u0004\u0008\u0018\u0010\u0007R\u001a\u0010\u0019\u001a\u00020\u00048GX\u0087\u0004\u00a2\u0006\u000c\u0012\u0004\u0008\u001a\u0010\u0002\u001a\u0004\u0008\u001b\u0010\u0007R\u001a\u0010\u001c\u001a\u00020\u00048GX\u0087\u0004\u00a2\u0006\u000c\u0012\u0004\u0008\u001d\u0010\u0002\u001a\u0004\u0008\u001e\u0010\u0007R$\u0010\u001f\u001a\u00020\u000b8GX\u0087\u0004\u00f8\u0001\u0000\u00f8\u0001\u0001\u00a2\u0006\u0010\n\u0002\u0010\u000f\u0012\u0004\u0008 \u0010\u0002\u001a\u0004\u0008!\u0010\u000eR\u001a\u0010\"\u001a\u00020\u00048GX\u0087\u0004\u00a2\u0006\u000c\u0012\u0004\u0008#\u0010\u0002\u001a\u0004\u0008$\u0010\u0007R\u001a\u0010%\u001a\u00020\u00048GX\u0087\u0004\u00a2\u0006\u000c\u0012\u0004\u0008&\u0010\u0002\u001a\u0004\u0008\'\u0010\u0007R\u001a\u0010(\u001a\u00020\u00048GX\u0087\u0004\u00a2\u0006\u000c\u0012\u0004\u0008)\u0010\u0002\u001a\u0004\u0008*\u0010\u0007R\u001a\u0010+\u001a\u00020\u00048GX\u0087\u0004\u00a2\u0006\u000c\u0012\u0004\u0008,\u0010\u0002\u001a\u0004\u0008-\u0010\u0007R\u001a\u0010.\u001a\u00020\u00048GX\u0087\u0004\u00a2\u0006\u000c\u0012\u0004\u0008/\u0010\u0002\u001a\u0004\u00080\u0010\u0007R\u0011\u00101\u001a\u00020\u00048G\u00a2\u0006\u0006\u001a\u0004\u00082\u0010\u0007R$\u00103\u001a\u00020\u000b8GX\u0087\u0004\u00f8\u0001\u0000\u00f8\u0001\u0001\u00a2\u0006\u0010\n\u0002\u0010\u000f\u0012\u0004\u00084\u0010\u0002\u001a\u0004\u00085\u0010\u000eR\u001a\u001