    <string name="gdpr_anonconsent_ads_accepted_body">Frábært. Auglýsingaaðilar okkar munu ekki safna gögnum um þig í gegnum þetta forrit til að sérsníða auglýsingar. Þú munt enn sjá auglýsingar en þær henta kannski minna þínum áhugasviðum.</string>
    <string name="gdpr_anonconsent_ads_body">Þú munt sjá auglýsingar svo að við getum veitt þér starfhæft forrit án endurgjalds, en þær gætu hentað minna þínum áhugasviðum. Engir prófílar á netinu verða búnir til.</string>
    <string name="gdpr_anonconsent_ads_body_two">Með samþykki þínu staðfestir þú að þú ert eldri en 16 ára og samþykkir að sjá almennar auglýsingar.</string>
    <string name="gdpr_anonconsent_ads_reject">Nei, takk. Ég vil frekar borga</string>
    <string name="gdpr_anonconsent_ads_title">Ekkert mál, við erum með almennar auglýsingar</string>
    <string name="gdpr_consent_ads_accept">Já, ég samþykki</string>
    <string name="gdpr_consent_ads_accepted_accept">Loka</string>
    <string name="gdpr_consent_ads_accepted_body">Frábært! Við vonum að þú njótir sérstillinganna þinna en ef þú skiptir um skoðun getur þú breytt vali þínu með því að fara í stillingarnar í þessu appi.</string>
    <string name="gdpr_consent_ads_accepted_title">Sérsniðin upplifun samþykkt</string>
    <string name="gdpr_consent_ads_body">Þetta app sérstillir auglýsingaupplifun þína í gegnum Google og aðra samstarfsaðila. Með því að samþykkja muntu sjá auglýsingar sem passa betur við þig. Eftir því hverjar friðhelgisstillingar þínar eru, gætu samstarfsaðilar okkar safnað persónulegum gögnum og unnið úr þeim. Frekari upplýsingar.</string>
    <string name="gdpr_consent_ads_body_two">Með samþykki þínu staðfestir þú að þú ert eldri en 16 ára og vilt fá sérstillta upplifun.</string>
    <string name="gdpr_consent_ads_reject">Nei, takk fyrir</string>
    <string name="gdpr_consent_ads_title">Sérstilltu upplifun þína</string>
    <string name="gdpr_paidconsent_ads_accept">Fá útgáfu sem borga þarf fyrir</string>
    <string name="gdpr_paidconsent_ads_accept_inapp">Fá uppfærslu</string>
