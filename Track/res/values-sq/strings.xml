    <string name="gdpr_anonconsent_ads_accepted_body">"Shkëlqyeshëm. Partnerët tanë të reklamave nuk do të mbledhin të dhënat tuaja nëpërmjet këtij aplikacioni për reklama jo të personalizuara. Përsëri do t'ju shfaqen reklama por ato nuk do të kenë lidhje me interesat tuaja."</string>
    <string name="gdpr_anonconsent_ads_body">"Për t'ju mundësuar aplikacion falas dhe funksional do t'ju shfaqen reklama por ato nuk do të kenë lidhje me interesat tuaja. Nuk krijohen profile në linjë."</string>
    <string name="gdpr_anonconsent_ads_body_two">Duke pranuar, ju konfirmoni se jeni mbi 16 vjeç dhe i pranoni reklamat jo të personalizuara.</string>
    <string name="gdpr_anonconsent_ads_reject">Jo, faleminderit. Preferoj të paguaj.</string>
    <string name="gdpr_anonconsent_ads_title">Pa problem, kemi reklama jo të personalizuara</string>
    <string name="gdpr_consent_ads_accept">Po, pranoj.</string>
    <string name="gdpr_consent_ads_accepted_accept">Mbyll</string>
    <string name="gdpr_consent_ads_accepted_body">Shkëlqyeshëm! Shpresojmë të kënaqeni me përvojën tuaj të personalizuar, por nëse ndryshoni mendje mund të ndryshoni edhe zgjedhjen tuaj duke shkuar te cilësimet e këtij aplikacioni.</string>
    <string name="gdpr_consent_ads_accepted_title">Eksperienca e personalizuar u pranua</string>
    <string name="gdpr_consent_ads_body">Ky aplikacion personalizon eksperiencën tuaj të reklamave nëpërmjet Google dhe partnerëve të tjerë. Duke pranuar ju do të shikoni reklama që kanë më shumë rëndësi për ju. Në varësi të cilësimeve tuaja të privatësisë partnerët tanë mund të mbledhin dhe të përpunojnë të dhënat personale. Mëso më shumë.</string>
    <string name="gdpr_consent_ads_body_two">Duke pranuar, ju konfirmoni se jeni më i madh se 16 vjeç dhe dëshironi një eksperiencë të personalizuar.</string>
    <string name="gdpr_consent_ads_reject">Jo, faleminderit.</string>
    <string name="gdpr_consent_ads_title">Personalizo eksperiencën</string>
    <string name="gdpr_paidconsent_ads_accept">Merr versionin me pagesë</string>
    <string name="gdpr_paidconsent_ads_accept_inapp">Merr përmirësim</string>
    <string name="gdpr_paidconsent_ads_accept_subscription">Merr abonim</string>
    <string name="gdpr_paidconsent_ads_accepted_accept">Mbyll</string>
    <string name="gdpr_paidconsent_ads_accepted_title">U pranua Reklama jo të personalizuara</string>
    <string name="gdpr_paidconsent_ads_body">"Edhe ne e duam aplikacionin pa reklama. Ju keni mundësi t'i hiqni reklamat duke e përmirësuar aplikacionin në versionin me pagesë."</string>
    <string name="gdpr_paidconsent_ads_body_two">"Nëse ju nuk dëshironi të paguani për këtë aplikacion, ju lutemi të kuptoni se ne kemi nevojë për lejen tuaj për t'ju shfaqur reklama për qëllime monetizimi."</string>
