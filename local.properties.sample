# Android SDK path
sdk.dir=/path/to/Android/Sdk

# App secrets (placeholder values)
SKYTRACE_API_BASE_URL=https://api.example.com/
SKYTRACE_API_KEY=replace_me

# OAuth / integrations
SKYTRACE_OAUTH_CLIENT_ID=replace_me
SKYTRACE_OAUTH_REDIRECT_SCHEME=com.wisso.skytrace

# Maps provider
SKYTRACE_MAPS_API_KEY=replace_me
